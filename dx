const video=$("video"),cv=$("cv"),ctx=cv.getContext("2d");
let landmarker=null, hist=[], cooldownUntil=0;

async function initHand(){
  const vision=await FilesetResolver.forVisionTasks("https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18/wasm");
  landmarker=await HandLandmarker.createFromOptions(vision,{
    baseOptions:{modelAssetPath:"https://storage.googleapis.com/mediapipe-models/hand_landmarker/hand_landmarker/float16/1/hand_landmarker.task",delegate:"GPU"},
    runningMode:"VIDEO",numHands:1});
}
async function startCamera(){
  const stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:"user",width:480,height:640}});
  video.srcObject=stream; await video.play();
  $("cam").classList.add("on");
  cv.width=video.videoWidth||480; cv.height=video.videoHeight||640;
  requestAnimationFrame(loop);
}
function loop(){
  if(landmarker&&video.readyState>=2){
    const res=landmarker.detectForVideo(video,performance.now());
    handle(res);
    draw(res);
  }
  requestAnimationFrame(loop);
}
const HD=(a,b)=>Math.hypot(a.x-b.x,a.y-b.y);
// 손목(0) 기준 거리 비율로 폄 판정 — 손 방향(상하/기울기)과 무관하게 동작
function fingerExt(lm){const w=lm[0],tip=[8,12,16,20],pip=[6,10,14,18];
  return tip.map((t,i)=>HD(lm[t],w)>HD(lm[pip[i]],w)*1.12);}      // 팁이 PIP보다 손목에서 멀면 폄
// 👌 OK : 엄지·검지 끝이 맞닿아 원 + 중지·약지·소지 폄 (주먹/손바닥과 확연히 구분)
function isOK(lm){const f=fingerExt(lm);
  return HD(lm[4],lm[8]) < HD(lm[0],lm[9])*0.5 && f[1] && f[2] && f[3];}
function classify(lm){const f=fingerExt(lm),up=f.filter(Boolean).length;
  if(isOK(lm))return "ok";                          // 👌 OK = 다른 컬러
  if(up<=1)return "fist";                           // ✊ 주먹 = 다음 상품
  if(f[0]&&f[1]&&!f[2]&&!f[3])return "scissors";    // ✌ 브이 = 이전 상품
  if(up>=3)return "palm";                            // 🖐 손바닥 = 이미지 좌·우
  return null;}
let poseHold=null,poseCount=0,palmZone=0,palmCount=0,startHold=0;
function handle(res){
  const now=performance.now();
  if($("overlay").style.display!=="none"){                 // 가이드 화면: 🖐 손바닥을 펴 들면 시작
    poseHold=null;poseCount=0;palmZone=0;palmCount=0;
    if(res&&res.landmarks&&res.landmarks.length&&classify(res.landmarks[0])==="palm"){
      $("clbl").textContent="🖐 인식됨 — 시작합니다";
      if(++startHold>=CONFIG.START_FRAMES){startHold=0;beginKiosk();}
    } else {startHold=0;$("clbl").textContent="🖐 손바닥을 펴서 보여주세요";}
    return;
  }
  if(!res||!res.landmarks||!res.landmarks.length){poseHold=null;poseCount=0;palmZone=0;palmCount=0;$("clbl").textContent="손을 보여주세요";return;}
  const lm=res.landmarks[0];
  const g=classify(lm);
  $("clbl").textContent = g==="fist"?"✊ 다음 상품":g==="scissors"?"✌ 이전 상품":g==="ok"?"👌 다른 컬러":g==="palm"?"🖐 좌·우 = 이미지":"손을 보여주세요";
  if(now<cooldownUntil)return;
  if(g==="fist"||g==="scissors"||g==="ok"){       // ✊ 다음 상품 / ✌ 이전 상품 / 👌 다른 컬러
    palmZone=0;palmCount=0;
    if(g===poseHold)poseCount++; else {poseHold=g;poseCount=1;}
    if(poseCount>=CONFIG.POSE_FRAMES){
      if(g==="ok")gestureColor(); else gestureProduct(g==="fist"?1:-1);
      cooldownUntil=now+CONFIG.COOLDOWN_MS;poseHold=null;poseCount=0;}
  } else if(g==="palm"){                          // 🖐 손바닥 위치(카메라 좌/우)로 이미지 넘김
    poseHold=null;poseCount=0;
    const sx=1-lm[9].x;                           // 화면(미러) 기준 가로 위치 0~1
    const zone = sx>CONFIG.ZONE?1 : sx<(1-CONFIG.ZONE)?-1 : 0;   // 우측=다음, 좌측=이전, 중앙=대기
    if(zone!==0){
      palmCount=(zone===palmZone)?palmCount+1:1; palmZone=zone;
      if(palmCount>=CONFIG.PALM_FRAMES){gestureImage(zone>0?1:-1);cooldownUntil=now+CONFIG.IMG_COOLDOWN_MS;palmCount=0;}
    } else {palmZone=0;palmCount=0;}
  } else {poseHold=null;poseCount=0;palmZone=0;palmCount=0;}
}
function draw(res){
  ctx.clearRect(0,0,cv.width,cv.height);
  if(!res||!res.landmarks||!res.landmarks.length)return;
  const lm=res.landmarks[0][9];
  ctx.beginPath();ctx.arc((1-lm.x)*cv.width,lm.y*cv.height,Math.max(6,cv.width*0.03),0,7);
  ctx.fillStyle="rgba(30,127,181,.9)";ctx.fill();
}

/* ===== 시작 진입 (터치 START / 🖐 손바닥 공통) ===== */
function beginKiosk(){
  try{ const fr=$("frame"); if(!document.fullscreenElement && fr.requestFullscreen) fr.requestFullscreen(); }catch(_){}
  $("overlay").style.display="none";
  $("exitBtn").style.display="block";
  resetIdle();
}
/* 카메라+손추적 시작 (중복 호출 안전) */
async function ensureCamera(){
  try{ if(!landmarker) await initHand(); if(!video.srcObject) await startCamera(); camReady=true; renderHint(); return true; }
  catch(err){ console.warn("gesture disabled:",err); $("cam").classList.remove("on"); camReady=false; renderHint(); return false; }
}
/* 시작 버튼(터치) — 손동작이 안 될 때의 대체 진입 */
$("start").addEventListener("click",()=>{ beginKiosk(); ensureCamera(); });
/* 손바닥으로 시작할 수 있도록 로드 직후 카메라 미리 켜기 (가이드 화면에서도 손 인식) */
ensureCamera();

/* 종료하기 → 첫(시작) 화면 복귀. 카메라는 유지하여 🖐 손바닥으로 재시작 가능 */
function exitKiosk(){
  if(document.fullscreenElement) document.exitFullscreen().catch(()=>{});
  shoe=0;colorIdx=0;img=0;startHold=0;renderInfo();buildTrack();renderIdots();renderPbar();renderOverlay();
  $("exitBtn").style.display="none";
  $("overlay").style.display="flex";
}
$("exitBtn").addEventListener("click",exitKiosk);
document.addEventListener("fullscreenchange",()=>{ if(!document.fullscreenElement && $("exitBtn").style.display==="block") exitKiosk(); });
</script>
