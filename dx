let shoe=0,colorIdx=0,img=0,lang="kr",axis=null,drag=false,x0=0,y0=0,dx=0,dy=0,IW=0,camReady=false;
const $=id=>document.getElementById(id);
const stage=$("stage"),ivp=$("ivp"),track=$("track"),content=$("content");
const curColor=()=>PRODUCTS[shoe].colors[colorIdx];

function renderLangs(){$("langs").innerHTML=["kr","en","cn","jp"].map(l=>`<button class="lang ${l===lang?"on":""}" onclick="setLang('${l}')">${T[l].lang}</button>`).join("");}
function buildTrack(){const p=PRODUCTS[shoe],c=curColor();
  track.innerHTML=c.imgs.map(im=>{const src=encodeURI(im.src);
    const alt=`${p.nameEn} ${c.code} ${VIEW[im.view][lang]}`;
    const phl=`<div class="phl"><span class="pn">${p.nameEn}</span><span class="pv">${VIEW[im.view][lang]}</span></div>`;
    // 모델컷·제품컷 모두 4:5 비율 적용 완료 → 별도 가공 없이 그대로 cover
    // PNG(투명 배경 가능)는 셀에 화이트 배경을 깔고, 투명영역으로 비치는 플레이스홀더 텍스트는 숨김
    const isPng=/\.png(\?|$)/i.test(im.src);
    const cellBg=isPng?' style="background:#fff"':'';
    return `<div class="cell"${cellBg}>${isPng?'':phl}<img src="${src}" alt="${alt}" onerror="this.remove()"></div>`;}).join("");
  size();updateOv();}
function updateOv(){const c=curColor();$("counter").textContent=(img+1)+" / "+c.imgs.length;updateEdge();}
function updateEdge(){const len=curColor().imgs.length,eN=$("edgeNext"),eP=$("edgePrev");
  eN.textContent=EDGE.next[lang];eP.textContent=EDGE.prev[lang];
  eN.style.opacity=(img===len-1&&shoe<PRODUCTS.length-1)?"1":"0";
  eP.style.opacity=(img===0&&shoe>0)?"1":"0";}
function renderInfo(){const p=PRODUCTS[shoe],fb=F[p.flag][lang],c=curColor();
  const nm=lang==="kr"?p.nameKr:p.nameEn;
  const chips=p.colors.map((co,k)=>`<button class="chip-b ${k===colorIdx?"on":""}" style="background:${co.chip}" onclick="setColor(${k})" aria-label="${co.name.en}"></button>`).join("");
  const sz=p.sizes,step=sz.length>1?sz[1]-sz[0]:0;
  const sizeRange=`<span class="sizerange"><b>${sz[0]}–${sz[sz.length-1]}mm</b>${step?`<em>${step}mm ${STEPU[lang]}</em>`:""}</span>`;
  $("info").innerHTML=
    `<div class="tags"><span class="badge ${p.flag==="best"?"main":"sub"}">${fb}</span><span class="pno">${p.code}</span>${sizeRange}</div>`+
    `<div class="nrow"><div class="nleft"><span class="name">${nm}</span><span class="chips">${chips}</span></div><span class="price">${p.price}</span></div>`+
    `<div class="ensub">${p.nameEn.toUpperCase()} · ${p.tag[lang]}</div>`+
    `<div class="desc">${p.desc[lang]}</div>`+
    `<div class="spec">${SPEC.wt[lang]} ${p.weight} · ${SPEC.hl[lang]} ${p.heel}</div>`;}
function renderIdots(){const c=curColor();$("idots").innerHTML=c.imgs.map((im,k)=>`<button class="idot ${k===img?"on":""}" onclick="imgDot(${k})" aria-label="${k+1}"></button>`).join("");}
function renderPbar(){$("pbar").innerHTML=PRODUCTS.map((p,i)=>`<button class="seg ${i===shoe?"on":""}" onclick="shoeJump(${i})" aria-label="${p.nameEn}"></button>`).join("");}
function renderHint(){$("hint").innerHTML=`<span>${camReady?T[lang].hint:TOUCH[lang]}</span>`;}
function size(){IW=ivp.clientWidth;[...track.children].forEach(c=>c.style.width=IW+"px");place(false);}
function place(a){
  track.style.transition=a?"transform .38s cubic-bezier(.22,.61,.36,1)":"none";
  let off=axis==="x"?dx:0;
  const len=curColor().imgs.length;            // 양끝에서 고무줄 저항
  if((img===0&&off>0)||(img===len-1&&off<0))off*=0.35;
  track.style.transform=`translateX(${-img*IW+off}px)`;
}
function dim(){$("hint").style.opacity=".4";}
function setImg(n){const len=curColor().imgs.length;img=Math.max(0,Math.min(len-1,n));place(true);renderIdots();updateOv();dim();resetIdle();}
/* 이미지 이동 — 끝까지 가면 다음/이전 상품으로 자동 전환 */
function navImage(dir){
  const len=curColor().imgs.length, n=img+dir;
  if(n>=0&&n<len){setImg(n);return;}
  if(dir>0){                                     // 마지막 이미지 다음 → 다음 상품 첫 이미지
    if(shoe<PRODUCTS.length-1)shoeStep(1); else setImg(len-1);
  }else{                                          // 첫 이미지 이전 → 이전 상품 마지막 이미지
    if(shoe>0){shoeStep(-1);img=curColor().imgs.length-1;renderIdots();updateOv();place(true);dim();resetIdle();}
    else setImg(0);
  }
}
function setColor(k){const p=PRODUCTS[shoe];k=Math.max(0,Math.min(p.colors.length-1,k));if(k===colorIdx)return;
  colorIdx=k;img=0;renderInfo();buildTrack();renderIdots();dim();resetIdle();}
function shoeStep(d){const ns=Math.max(0,Math.min(PRODUCTS.length-1,shoe+d));const dir=Math.sign(d)||1;
  if(ns===shoe){content.style.transition="transform .25s ease";content.style.transform="translateY(0)";content.style.opacity="1";return;}
  shoe=ns;colorIdx=0;img=0;renderInfo();buildTrack();renderIdots();renderPbar();dim();resetIdle();
  content.style.transition="none";content.style.transform=`translateY(${dir*4}cqw)`;content.style.opacity=".4";
  requestAnimationFrame(()=>{content.style.transition="transform .3s ease, opacity .3s ease";content.style.transform="translateY(0)";content.style.opacity="1";});}
function renderOverlay(){const t=INTRO[lang];
  $("ovLangs").innerHTML=["kr","en","cn","jp"].map(l=>`<button class="ovlang ${l===lang?"on":""}" onclick="setLang('${l}')">${T[l].lang}</button>`).join("");
  $("ovTitle").textContent=t.title;$("ovGuide").innerHTML=t.guide;$("start").textContent=t.start;
  $("exitBtn").textContent=t.exit;}
window.setLang=l=>{lang=l;renderLangs();renderHint();buildTrack();renderInfo();renderIdots();renderOverlay();resetIdle();};

window.setColor=k=>setColor(k);
window.shoeBtn=d=>shoeStep(d);
window.shoeJump=i=>shoeStep(i-shoe);
window.imgDot=k=>setImg(k);

/* 터치 스와이프 = 이미지(좌우)만 */
let vx=0,lastX=0,lastT=0;
stage.addEventListener("dragstart",e=>e.preventDefault());
stage.addEventListener("pointerdown",e=>{
  drag=true;axis=null;x0=e.clientX;y0=e.clientY;dx=0;dy=0;
  vx=0;lastX=e.clientX;lastT=e.timeStamp;
  track.style.transition="none";stage.style.cursor="grabbing";
  try{stage.setPointerCapture(e.pointerId);}catch(_){}
});
stage.addEventListener("pointermove",e=>{if(!drag)return;
  dx=e.clientX-x0;dy=e.clientY-y0;
  if(!axis&&(Math.abs(dx)>6||Math.abs(dy)>6))axis=Math.abs(dx)>=Math.abs(dy)?"x":"y";
  if(axis==="x"){
    e.preventDefault();
    const now=e.timeStamp,dt=now-lastT;
    if(dt>0){vx=(e.clientX-lastX)/dt;lastX=e.clientX;lastT=now;}  // px/ms
    place(false);
  }
});
function endPtr(e){if(!drag)return;drag=false;stage.style.cursor="grab";
  try{if(e&&e.pointerId!=null)stage.releasePointerCapture(e.pointerId);}catch(_){}
  const wasX=axis==="x";let dir=0;
  if(wasX){const dist=IW*0.18,flick=0.5;        // 거리 18% 또는 플릭 속도로 넘김
    if(dx<-dist||vx<-flick)dir=1;else if(dx>dist||vx>flick)dir=-1;}
  dx=0;dy=0;axis=null;
  if(wasX&&dir)navImage(dir);                    // 상품 경계 넘으면 다음/이전 상품으로
  else if(wasX){place(true);resetIdle();}        // 임계 미달 → 제자리 복귀
  else resetIdle();
}
stage.addEventListener("pointerup",endPtr);stage.addEventListener("pointercancel",endPtr);
window.addEventListener("resize",size);
document.addEventListener("contextmenu",e=>e.preventDefault());

/* 무조작 5분 → 처음 가이드(시작) 화면으로 복귀 */
let idleT=null;
function resetIdle(){clearTimeout(idleT);idleT=setTimeout(goIntro,120000);}   /* 유휴 2분 → 시작화면 복귀 */
function goIntro(){shoe=0;colorIdx=0;img=0;renderInfo();buildTrack();renderIdots();renderPbar();renderOverlay();
  $("exitBtn").style.display="none";$("overlay").style.display="flex";$("hint").style.opacity="1";}

