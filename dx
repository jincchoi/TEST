<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
<title>Discovery Expedition — Summer Shoes (Gesture)</title>
<!--
  매장 체험형 태블릿 — 손동작 인식 버전 (세로형 / Portrait, 1400 x 2000)  · FINAL v3
  ─────────────────────────────────────────────────────────────
  · ✌ 가위 = 이전 상품 / ✊ 주먹 = 다음 상품 · 손 좌우 = 이미지 · 컬러칩 = 컬러 전환
  · 간격/위치/크기는 아래 :root 의 --변수 로 조정합니다(단위 cqw = 화면폭의 1%).
  · [v3 변경]
    1) ⚙ 조절 패널: 로고 높이 / 상단 여백 / 상품명-컬러칩 간격 실시간 조절 (현재값 복사 가능)
    2) 컬러칩 위치를 '상품명 뒤 일정 간격'(flex)으로 변경 → 상품명 길이와 무관하게 동일 간격
  [이미지/문구 교체]  PRODUCTS 배열의 colors[].imgs 경로(이 HTML 기준 상대경로)를 교체.
  [단일 파일 배포]   embed-images.bat 실행 → *_embed.html 생성(이미지 내장).
-->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"><style>
  :root{
    --bg:#F4F1EA; --surface:#FFFFFF; --ink:#1B2630; --muted:#6A7079;
    --line:rgba(27,38,48,.12); --line-2:rgba(27,38,48,.22);
    --accent:#1E7FB5; --accent-soft:#DCECF5; --chip:rgba(255,255,255,.9);
    --font:"Pretendard","Pretendard Variable",-apple-system,"Noto Sans KR","Noto Sans JP","Noto Sans SC",system-ui,sans-serif;

    /* ===== 간격/위치/크기 (단위 cqw = 화면폭의 1%) ===== */
    --header-pt:2.2cqw;        /* [조절] 상단 여백 */
    --pad-x:4.5cqw;
    --logo-h:7.7cqw;           /* [조절] 브랜드 로고 높이 */
    --lang-size:2.2cqw;
    --pbar-mb:3cqw;
    --img-radius:2.5cqw;
    --counter-size:2.5cqw;
    --idots-pt:1.6cqw;
    --info-h:30.6cqw;          /* [조절] 정보영역 높이 */
    --tags-top:2.8cqw;
    --badge-size:2.1cqw;
    --name-top:5.7cqw;
    --name-size:4.5cqw;
    --price-size:3.6cqw;
    --name-chip-gap:5.0cqw;    /* [조절] 상품명 ↔ 컬러칩 간격 (모든 상품 동일) */
    --chips-gap:2.2cqw;
    --chip-d:3.5cqw;
    --ensub-top:14.0cqw;       /* [조절] 영문서브 위치 */
    --ensub-size:2.3cqw;
    --desc-top:18.6cqw;        /* [조절] 설명문 위치 */
    --desc-size:2.6cqw;
    --spec-top:24.6cqw;        /* [조절] 스펙/구분선 위치 */
    --spec-size:2.1cqw;
    --hint-size:2.1cqw;
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{height:100%;margin:0;background:#000;overflow:hidden;font-family:var(--font);
    -webkit-user-select:none;user-select:none;-webkit-touch-callout:none}
  #frame{height:100dvh;aspect-ratio:1200/2000;max-width:100vw;margin:0 auto;position:relative;
    background:var(--bg);container-type:inline-size;overflow:hidden}
  #app{position:absolute;inset:0;display:flex;flex-direction:column}

  header{display:flex;align-items:center;gap:2cqw;padding:var(--header-pt) var(--pad-x) 1cqw;flex:0 0 auto}
  /* 로고 PNG 좌측 여백(폭의 6.73%) 보정 → 로고 시작점을 이미지 좌측 끝선과 정렬 (로고 높이에 비례) */
  .brand-logo{height:var(--logo-h);width:auto;display:block;margin-left:calc(var(--logo-h) * -0.2427)}
  .langs{display:flex;gap:1.2cqw;flex:0 0 auto;flex-wrap:nowrap}
  .lang{font-family:var(--font);font-size:var(--lang-size);color:var(--muted);background:transparent;
    border:0.12cqw solid var(--line-2);border-radius:3cqw;padding:1.4cqw 2.8cqw;cursor:pointer;line-height:1;
    white-space:nowrap;flex:0 0 auto}
  .lang.on{background:var(--accent);color:#fff;border-color:var(--accent)}
  /* 종료(END) 버튼 — 헤더 우측 끝(언어 버튼을 좌측으로 밀어냄) */
  #exitBtn{margin-left:auto;display:none;font-family:var(--font);font-size:var(--lang-size);font-weight:700;
    color:#fff;background:var(--accent);border:0.12cqw solid var(--accent);border-radius:3cqw;
    padding:1.4cqw 3.4cqw;cursor:pointer;line-height:1;letter-spacing:.1cqw;white-space:nowrap;flex:0 0 auto}

  #content{flex:1 1 auto;display:flex;flex-direction:column;min-height:0;padding:0 var(--pad-x);will-change:transform}
  .pbar{display:flex;gap:1.5cqw;padding:0 0 var(--pbar-mb);flex:0 0 auto}
  .seg{flex:1;height:0.85cqw;border-radius:1cqw;background:var(--line-2);border:0;padding:0;cursor:pointer;transition:background .25s}
  .seg.on{background:var(--accent)}

  .stage{position:relative;flex:1 1 auto;min-height:0;display:flex;align-items:center;justify-content:center;touch-action:none;cursor:grab}
  .viewport{position:relative;height:100%;width:100%;border-radius:var(--img-radius);overflow:hidden;background:#E6E8E6}
  .track{display:flex;height:100%;will-change:transform}
  .cell{flex:0 0 auto;height:100%;position:relative;overflow:hidden;background:#E6E8E6}
  .cell img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;
    -webkit-user-drag:none;user-select:none;pointer-events:none}
  /* 모델컷: 같은 이미지를 흐리게 확대해 배경을 채우고(bgblur), 원본은 잘림 없이 전체 표시(fg/contain) */
  .cell img.bgblur{object-fit:cover;filter:blur(1.8cqw) saturate(1.08);transform:scale(1.12);z-index:0}
  .cell img.fg{object-fit:contain;z-index:1}
  .phl{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1cqw;color:#3A332C}
  .phl .pn{font-size:5cqw;font-weight:700;opacity:.5;letter-spacing:.1cqw}
  .phl .pv{font-size:2.8cqw;opacity:.45;text-transform:uppercase;letter-spacing:.4cqw}
  .ov{position:absolute;z-index:2;pointer-events:none}
  .counter{top:2.6cqw;right:2.6cqw;background:var(--chip);color:var(--ink);font-size:var(--counter-size);padding:1cqw 2.4cqw;border-radius:6cqw}
  /* 상품 경계 예고 — 마지막/첫 이미지에서만 표시 */
  .edge{top:50%;transform:translateY(-50%);background:var(--chip);color:var(--ink);font-size:2.3cqw;font-weight:700;
    padding:1.4cqw 2.6cqw;border-radius:6cqw;opacity:0;transition:opacity .3s;box-shadow:0 0.4cqw 1.4cqw rgba(18,40,56,.2)}
  .edge.prev{left:2.6cqw}
  .edge.next{right:2.6cqw}

  .idots{display:flex;gap:1.4cqw;justify-content:center;padding:var(--idots-pt) 0 0.4cqw;flex:0 0 auto}
  .idot{width:1.5cqw;height:1.5cqw;border-radius:50%;background:var(--line-2);border:0;padding:0;cursor:pointer}
  .idot.on{width:5cqw;border-radius:.8cqw;background:var(--accent)}

  /* ===== 정보 영역 : 고정 레이아웃(언어 무관 동일 위치) ===== */
  .info{flex:0 0 auto;position:relative;height:var(--info-h);padding:1cqw 1cqw 0}
  .tags{position:absolute;top:var(--tags-top);left:1cqw;display:flex;gap:1.2cqw;align-items:center}
  .badge{display:inline-flex;align-items:center;justify-content:center;font-size:var(--badge-size);line-height:1;padding:0.8cqw 2cqw 0.64cqw;border-radius:2cqw}
  .badge.main{background:var(--accent);color:#fff}
  .badge.sub{background:var(--accent-soft);color:var(--accent)}
  .pno{display:inline-flex;align-items:center;justify-content:center;font-size:calc(var(--badge-size) - 0.1cqw);line-height:1;padding:0.75cqw 1.8cqw 0.59cqw;border-radius:2cqw;border:0.12cqw solid var(--line-2);color:var(--muted);letter-spacing:.06cqw}

  /* nrow : [상품명 — 컬러칩] 좌측 그룹 + 가격 우측 (상품명-칩 간격 고정) */
  .nrow{position:absolute;top:var(--name-top);left:1cqw;right:1cqw;height:7cqw;display:flex;align-items:flex-end;justify-content:space-between;gap:2cqw}
  .nleft{display:flex;align-items:center;gap:var(--name-chip-gap);min-width:0}
  .name{font-size:var(--name-size);font-weight:700;color:var(--ink);letter-spacing:-.05cqw;white-space:nowrap;line-height:1}
  .price{font-size:var(--price-size);font-weight:600;color:var(--ink);white-space:nowrap;line-height:1;flex:0 0 auto}
  .chips{display:flex;gap:var(--chips-gap);align-items:center;flex:0 0 auto}
  .chip-b{width:var(--chip-d);height:var(--chip-d);border-radius:50%;border:0.2cqw solid var(--line-2);padding:0;cursor:pointer;
    transition:box-shadow .15s,transform .12s;background-clip:padding-box}
  .chip-b:active{transform:scale(.9)}
  .chip-b.on{box-shadow:0 0 0 0.6cqw var(--surface),0 0 0 1.05cqw var(--accent)}

  .ensub{position:absolute;top:var(--ensub-top);left:1cqw;right:1cqw;height:3.6cqw;overflow:hidden;
    font-size:var(--ensub-size);color:var(--accent);letter-spacing:.02cqw;white-space:nowrap;text-overflow:ellipsis}
  .desc{position:absolute;top:var(--desc-top);left:1cqw;right:1cqw;height:calc(var(--spec-top) - var(--desc-top) - 0.6cqw);overflow:hidden;
    font-size:var(--desc-size);line-height:1.45;color:var(--ink)}
  .spec{position:absolute;top:var(--spec-top);left:1cqw;right:1cqw;padding-top:1.2cqw;border-top:0.12cqw solid var(--line);
    font-size:var(--spec-size);color:var(--muted)}

  .hint{flex:0 0 auto;display:flex;align-items:center;justify-content:center;gap:2cqw;color:var(--muted);font-size:var(--hint-size);padding:1cqw 0 1.6cqw;transition:opacity .4s}

  /* 카메라 미리보기 + 손동작 상태 */
  .cam{position:absolute;left:6cqw;top:18cqw;width:19cqw;aspect-ratio:3/4;border-radius:2.4cqw;overflow:hidden;background:#111;z-index:21;border:0.2cqw solid var(--line-2);display:none}
  .cam.on{display:block}
  .cam video{width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
  .cam canvas{position:absolute;inset:0;width:100%;height:100%}
  .cam .clbl{position:absolute;top:1cqw;left:1cqw;font-size:1.9cqw;color:#fff;background:rgba(0,0,0,.45);padding:.4cqw 1.4cqw;border-radius:3cqw}
  .flash{position:absolute;top:40%;left:50%;transform:translate(-50%,-50%);z-index:7;font-size:9cqw;color:var(--accent);
    opacity:0;pointer-events:none;font-weight:700}
  .flash.go{animation:pop .55s ease}
  @keyframes pop{0%{opacity:0;transform:translate(-50%,-50%) scale(.7)}30%{opacity:.95}100%{opacity:0;transform:translate(-50%,-50%) scale(1.25)}}

  #overlay{position:absolute;inset:0;z-index:20;background:rgba(18,40,56,.94);color:#fff;
    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3.2cqw;text-align:center;padding:9cqw}
  #overlay h1{font-size:5cqw;font-weight:700;margin:0}
  #overlay p{font-size:3cqw;color:#e8e3da;margin:0;line-height:1.6}
  .ovlangs{display:flex;gap:1.8cqw;flex-wrap:wrap;justify-content:center;margin-bottom:1cqw}
  .ovlang{font-family:var(--font);font-size:2.9cqw;color:#fff;background:rgba(255,255,255,.12);
    border:0.2cqw solid rgba(255,255,255,.55);border-radius:6cqw;padding:1.5cqw 4cqw;cursor:pointer;line-height:1;white-space:nowrap}
  .ovlang.on{background:#fff;color:var(--ink);border-color:#fff}
  #start{font-family:var(--font);font-size:3.4cqw;font-weight:600;color:#fff;background:var(--accent);
    border:0;border-radius:3cqw;padding:3cqw 8cqw;cursor:pointer;margin-top:1cqw;white-space:nowrap}
  .ghand{font-size:9cqw;animation:palm 1.4s ease-in-out infinite}
  @keyframes palm{0%,100%{transform:translateX(-2.6cqw) rotate(-6deg)}50%{transform:translateX(2.6cqw) rotate(6deg)}}
  @media(prefers-reduced-motion:reduce){.ghand{animation:none}}

  /* ===== 사이즈 태그 (상품코드 옆 · 코드 pill과 동일한 태그 스타일) ===== */
  .sizerange{display:inline-flex;align-items:baseline;gap:0.8cqw;
    font-size:calc(var(--badge-size) - 0.1cqw);line-height:1;padding:0.75cqw 1.8cqw 0.59cqw;
    border-radius:2cqw;border:0.12cqw solid var(--line-2);color:var(--muted);
    letter-spacing:.04cqw;font-variant-numeric:tabular-nums}
  .sizerange b{font-weight:700}
  .sizerange em{font-style:normal;font-weight:500;color:rgba(27,38,48,.4);font-size:0.82em}

</style>
</head>
<body>
<div id="frame">
  <div id="app">
    <header>
      <img class="brand-logo" src="LOGO_gREY-01.png" alt="Discovery Expedition">
      <div class="langs" id="langs"></div>
      <button id="exitBtn">END</button>
    </header>
    <div id="content">
      <div class="pbar" id="pbar"></div>
      <div class="stage" id="stage">
        <div class="viewport" id="ivp">
          <div class="track" id="track"></div>
          <div class="ov counter" id="counter"></div>
          <div class="ov edge prev" id="edgePrev"></div>
          <div class="ov edge next" id="edgeNext"></div>
        </div>
        <div class="flash" id="flash"></div>
      </div>
      <div class="idots" id="idots"></div>
      <div class="info" id="info"></div>
    </div>
    <div class="hint" id="hint"></div>
    <div class="cam" id="cam"><video id="video" playsinline muted></video><canvas id="cv"></canvas><div class="clbl" id="clbl">손 인식</div></div>
  </div>
  <div id="overlay">
    <div class="ovlangs" id="ovLangs"></div>
    <div class="ghand">&#128400;</div>
    <h1 id="ovTitle"></h1>
    <p id="ovGuide"></p>
    <button id="start"></button>
  </div>
</div>

<script type="module">
import { HandLandmarker, FilesetResolver } from "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.18";

/* ===== 손동작 민감도 설정 ===== */
const CONFIG={ POSE_FRAMES:6, PALM_FRAMES:4, START_FRAMES:12, COOLDOWN_MS:1200, IMG_COOLDOWN_MS:700, ZONE:0.62 };

/* ===== 다국어 라벨 ===== */
const T={
  kr:{lang:"한국어",hint:"🖐 좌·우 이미지 · ✌ 이전 · ✊ 다음 상품 · 👌 컬러"},
  en:{lang:"EN",hint:"🖐 image · ✌ prev · ✊ next · 👌 color"},
  cn:{lang:"中文",hint:"🖐 图片 · ✌ 上一 · ✊ 下一 · 👌 颜色"},
  jp:{lang:"日本語",hint:"🖐 画像 · ✌ 前 · ✊ 次 · 👌 カラー"}
};
const F={best:{kr:"베스트",en:"Best",cn:"热卖",jp:"ベスト"},new:{kr:"26SS 신상품",en:"26SS New",cn:"26SS 新品",jp:"26SS NEW"}};
const VIEW={model:{kr:"모델컷",en:"Model",cn:"模特",jp:"モデル"},product:{kr:"제품컷",en:"Product",cn:"产品",jp:"製品"}};
const SPEC={wt:{kr:"무게",en:"Weight",cn:"重量",jp:"重さ"},hl:{kr:"굽 높이",en:"Heel",cn:"跟高",jp:"ヒール高"},sz:{kr:"사이즈",en:"Size",cn:"尺码",jp:"サイズ"}};
/* ===== 사이즈 단위 (다국어) ===== */
const STEPU={kr:"단위",en:"steps",cn:"间隔",jp:"刻み"};
/* 손동작 불가 시 힌트 / 상품 경계 예고 (다국어) */
const TOUCH={kr:"👆 화면을 터치해 둘러보세요",en:"👆 Tap the screen to browse",cn:"👆 触摸屏幕浏览",jp:"👆 画面をタッチして操作"};
const EDGE={next:{kr:"다음 상품 ›",en:"Next ›",cn:"下一款 ›",jp:"次の商品 ›"},prev:{kr:"‹ 이전 상품",en:"‹ Prev",cn:"‹ 上一款",jp:"‹ 前の商品"}};
/* ===== 시작 화면 안내 (언어별) ===== */
const INTRO={
  kr:{title:"손짓으로 둘러보세요",guide:"카메라에 손을 보여주시면 손동작으로 제품을 둘러볼 수 있어요.<br><br>🖐 <b>손바닥</b>을 좌·우로 움직여 이미지를 넘겨보세요<br>✌ <b>브이</b>는 이전 상품, ✊ <b>주먹</b>은 다음 상품<br>👌 <b>오케이(OK)</b> 손동작으로 다른 컬러도 확인해 보세요<br><br>화면을 터치하거나 컬러칩을 눌러도 됩니다.",start:"시작하기",exit:"종료하기"},
  en:{title:"Browse with a wave of your hand",guide:"Show your hand to the camera to explore the shoes with simple gestures.<br><br>🖐 Move your <b>palm</b> left or right to flip through images<br>✌ <b>V sign</b> for the previous style, ✊ <b>fist</b> for the next<br>👌 <b>OK sign</b> to see the other colors<br><br>You can also tap the screen or a color chip.",start:"Start",exit:"Exit"},
  cn:{title:"挥挥手即可浏览",guide:"将手伸到摄像头前，即可用手势轻松浏览商品。<br><br>🖐 左右移动<b>手掌</b>切换图片<br>✌ <b>V手势</b>看上一款，✊ <b>拳头</b>看下一款<br>👌 <b>OK手势</b>查看其他颜色<br><br>也可直接触摸屏幕或点击颜色。",start:"开始",exit:"退出"},
  jp:{title:"手の動きで見てみましょう",guide:"カメラに手をかざすと、ジェスチャーで商品を見られます。<br><br>🖐 <b>手のひら</b>を左右に動かして画像を切り替え<br>✌ <b>ピース</b>で前の商品、✊ <b>グー</b>で次の商品<br>👌 <b>OKサイン</b>で別のカラーを確認<br><br>画面タッチやカラーチップでも操作できます。",start:"スタート",exit:"終了"}
};

/* 이미지 묶음 헬퍼 — 모델컷 → 제품컷 순서로 결합 */
const mk=(model,product)=>[
  ...model.map(src=>({view:"model",src})),
  ...product.map(src=>({view:"product",src}))
];

/* ===== 콘텐츠 — 폴더 순서(웨이브제인 → 웨이브샌디) ===== */
const PRODUCTS=[
  {nameKr:"웨이브 제인",nameEn:"Wave Jane",code:"DXSH7275N",flag:"best",price:"₩99,000",weight:"234g",heel:"3.5cm",
